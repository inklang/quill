{
  "name": "@inklang/quill",
  "version": "0.3.10",
  "description": "Package manager CLI for the Ink programming language",
  "type": "module",
  "exports": {
    ".": "./dist/cli.js",
    "./grammar": "./src/grammar/api.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "src/",
    "compiler/",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "dist/cli.js",
  "bin": {
    "quill": "dist/cli.js",
    "q": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "ink",
    "package-manager"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@iarna/toml": "^3.0.0",
    "chokidar": "^5.0.0",
    "colorette": "^2.0.20",
    "commander": "^12.0.0",
    "semver": "^7.7.4",
    "tar": "^7.5.13"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inklang/quill.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/inklang/quill/issues"
  },
  "homepage": "https://github.com/inklang/quill#readme"
}
